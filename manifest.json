{
  "manifest_version": 3,
  "name": "my-notion-helper",
  "version": "1.0.0",
  "description": "Toggle Notion page lock status quickly.",
  "permissions": [
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "*://app.notion.com/*",
    "*://*.notion.so/*",
    "*://*.notion.site/*",
    "*://api.notion.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "page-lock/config.json",
        "utils/toast.html"
      ],
      "matches": [
        "*://app.notion.com/*",
        "*://*.notion.so/*",
        "*://*.notion.site/*"
      ]
    }
  ],
  "commands": {
    "toggle-lock": {
      "suggested_key": {
        "default": "Alt+L",
        "mac": "MacCtrl+L"
      },
      "description": "Toggle Notion page lock"
    }
  }
}
